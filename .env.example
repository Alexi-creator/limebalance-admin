# API-эндпоинт. В проде = /api (same-origin, хостовый nginx проксирует на бэкенд).
# В dev Vite проксирует /api → http://localhost:3000 (см. vite.config.ts).
VITE_API_URL=/api

# Имя Telegram-бота (без «@») для виджета логина.
VITE_TELEGRAM_BOT_USERNAME=

# Google OAuth client id.
VITE_GOOGLE_CLIENT_ID=

# Google Analytics 4 measurement id (формат G-XXXXXXXXXX). Пусто = аналитика выключена.
VITE_GA_MEASUREMENT_ID=
